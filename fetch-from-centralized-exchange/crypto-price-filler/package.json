{
  "name": "crypto-price-filler",
  "version": "1.0.0",
  "description": "Local NodeJS tool to fetch historical crypto prices and fill USD columns in CSV files",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "clean": "rm -f tests/mock-filled*.csv test.log test.html",
    "test": "vitest run --coverage --silent",
    "validate-parse": "node index.js --help >/dev/null 2>&1 || [ $? -eq 1 ] && echo 'CLI parses OK (normal exit 1 on --help/usage)' || (echo 'CLI crashed unexpectedly'; exit 1)",
    "test:strict": "npm run validate-parse && vitest run --coverage --silent",
    "test:ci": "vitest run -- --no-cache --coverage",
    "test:debug": "VERBOSE=1 vitest run -- --no-cache --reporter=verbose --coverage",
    "test:watch": "vitest --coverage"
  },
  "author": "Christopher M. Balz with Grok and Claude.ai",
  "license": "Apache-2.0",
  "dependencies": {
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "csv-writer": "^1.6.0",
    "luxon": "^3.5.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.17",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=21.1.0"
  }
}
